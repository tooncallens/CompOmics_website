/*-- scss:defaults --*/

// Logo-derived palette
// #276ba6 = logo blue  |  #d63729 = logo red  |  #3b3838 = logo charcoal
$primary:   #276ba6;
$secondary: #d63729;
$accent:    #1a4f7a;
$light:     #f5f7fa;
$dark:      #3b3838;
$code-bg:   #f0f4f8;

// Typography
$font-family-sans-serif: "Inter", system-ui, -apple-system, sans-serif;
$font-family-monospace:  "JetBrains Mono", "Fira Code", monospace;
$headings-font-weight:   700;

// Navbar — charcoal so negative (white) logo pops
$navbar-bg: #3b3838;
$navbar-fg: #f0f0f0;
$navbar-hl: #ffffff;

/*-- scss:rules --*/

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

// ── Global ───────────────────────────────────────────────────────────────────
body {
  color: $dark;
  font-size: 1rem;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

a { color: $primary; }
a:hover { color: $accent; text-decoration: none; }

h1, h2, h3, h4 { letter-spacing: -0.01em; color: $dark; }

hr {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent, #c5d3e0 20%, #c5d3e0 80%, transparent);
  margin: 2.5rem 0;
  opacity: 1;
}

// ── Navbar ───────────────────────────────────────────────────────────────────
.navbar {
  background-color: #3b3838 !important;
  border-bottom: none;
  box-shadow: 0 3px 16px rgba(0, 0, 0, 0.25);
}

.navbar-brand img {
  height: 48px;
  width: auto;
}

.navbar-brand {
  font-weight: 700;
  font-size: 1.05rem;
  letter-spacing: -0.01em;
  color: #f0f0f0 !important;
}

.nav-link {
  font-weight: 500;
  font-size: 0.92rem;
  letter-spacing: 0.01em;
  color: #e8e8e8 !important;

  &:hover, &.active {
    color: #ffffff !important;
    opacity: 1;
  }
}

// ── Footer ───────────────────────────────────────────────────────────────────
.nav-footer {
  border-top: 2px solid $secondary;
  background: $light;
  font-size: 0.875rem;
}

// ── Code blocks ──────────────────────────────────────────────────────────────
pre.sourceCode {
  background: $code-bg;
  border-left: 3px solid $primary;
  border-radius: 0.375rem;
}

// ── Vision section ───────────────────────────────────────────────────────────
.vision-section {
  padding: 3rem 0 2rem;
  align-items: center;
}

.vision-text {
  h3 {
    font-size: 1.55rem;
    font-weight: 800;
    color: $primary;
    margin-bottom: 1.1rem;
    position: relative;
    padding-bottom: 0.65rem;

    &::after {
      content: "";
      position: absolute;
      bottom: 0; left: 0;
      width: 48px;
      height: 3px;
      background: linear-gradient(90deg, $primary, $secondary);
      border-radius: 2px;
    }
  }

  p {
    text-align: justify;
    hyphens: none;
    color: #3a3a3a;
    font-size: 0.97rem;
  }
}

.vision-img {
  width: 100%;
  height: 100%;
  border-radius: 0.75rem;
  object-fit: cover;
  object-position: center;
  display: block;
  box-shadow: 0 8px 32px rgba(39, 107, 166, 0.15);
}

.vision-section .g-col-md-5 {
  display: flex;
  align-items: stretch;
}

// ── Stats row ────────────────────────────────────────────────────────────────
.stats-row {
  padding: 1rem 0 2rem;
  text-align: center;
  gap: 1.2rem !important;
}

.stat-tile {
  padding: 1.75rem 1rem;
  background: white;
  border-radius: 0.75rem;
  border: 1px solid #d5e3f0;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(39, 107, 166, 0.07);
  transition: transform 0.2s ease, box-shadow 0.2s ease;

  &::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: #3b3838;
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .stat-number {
    display: block;
    font-size: 2.6rem;
    font-weight: 800;
    background: linear-gradient(135deg, $primary 0%, $secondary 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }

  .stat-label {
    display: block;
    margin-top: 0.45rem;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a9bae;
  }
}

a.stat-tile-link {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  cursor: pointer;

  &:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(39, 107, 166, 0.15);
    text-decoration: none;
    color: inherit;
  }
}

// ── Nav tiles ────────────────────────────────────────────────────────────────
.nav-tiles-row {
  display: flex;
  gap: 1.5rem;
  margin: 2rem 0;

  @media (max-width: 768px) {
    flex-direction: column;
  }
}

.nav-tile {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2.4rem 1.5rem;
  background: white;
  border: 1px solid #d5e3f0;
  border-radius: 0.875rem;
  text-decoration: none;
  color: $dark;
  box-shadow: 0 3px 14px rgba(39, 107, 166, 0.08);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  position: relative;
  overflow: hidden;

  &::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 0;
    background: linear-gradient(180deg, rgba(39,107,166,0.03), rgba(214,55,41,0.05));
    transition: height 0.25s ease;
  }

  &:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(39, 107, 166, 0.18);
    border-color: $primary;
    color: $primary;
    text-decoration: none;

    &::after { height: 100%; }
    .nav-tile-icon { color: $secondary; transform: scale(1.12); }
  }

  .nav-tile-icon {
    font-size: 2.6rem;
    color: $primary;
    margin-bottom: 0.85rem;
    transition: color 0.18s ease, transform 0.18s ease;
    position: relative;
  }

  .nav-tile-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.45rem;
    position: relative;
  }

  .nav-tile-desc {
    font-size: 0.85rem;
    color: #6c757d;
    text-align: center;
    line-height: 1.5;
    position: relative;
  }
}

// ── LCMS diagram ─────────────────────────────────────────────────────────────
.lcms-container {
  margin: 1.5rem 0 2.5rem;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(39, 107, 166, 0.1);
  border: 1px solid #d5e3f0;
}

// ── Tools / content pages ────────────────────────────────────────────────────
h2 {
  margin-top: 2.5rem;
  padding-bottom: 0.4rem;
  border-bottom: 2px solid #e8d5d3;
  color: $primary;
}

h3 {
  margin-top: 1.8rem;
  color: $dark;
}

blockquote {
  border-left: 3px solid $primary;
  color: #555;
  font-size: 0.93rem;
  background: $light;
  padding: 0.75rem 1rem;
  border-radius: 0 0.4rem 0.4rem 0;
}

// ── Stat tile uniform charcoal (matches navbar) ────────────────────────────
.stats-row .stat-tile {
  border-color: #c5c0c0;
  &::before { background: #3b3838; }
  .stat-number {
    background: none;
    -webkit-text-fill-color: #3b3838;
    color: #3b3838;
  }
}

// ── Tool cards ────────────────────────────────────────────────────────────────
.tool-card {
  display: flex;
  gap: 0;
  background: white;
  border: 1px solid #d5e3f0;
  border-radius: 0.875rem;
  margin-bottom: 1.1rem;
  box-shadow: 0 2px 12px rgba(39, 107, 166, 0.07);
  overflow: hidden;
  transition: box-shadow 0.2s ease, transform 0.2s ease;

  &:hover {
    box-shadow: 0 6px 24px rgba(39, 107, 166, 0.14);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    flex-direction: column;
  }
}

.tool-body {
  flex: 1;
  padding: 1.35rem 1.5rem;
}

.tool-header {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  margin-bottom: 0.7rem;
}

.tool-icon {
  font-size: 1.15rem;
  color: $primary;
  flex-shrink: 0;
  width: 2.1rem;
  height: 2.1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(39, 107, 166, 0.1);
  border-radius: 0.4rem;
}

.tool-name {
  font-size: 1.1rem;
  font-weight: 700;
  color: $dark;
}

.tool-desc {
  font-size: 0.91rem;
  color: #4a4a4a;
  line-height: 1.65;
  margin-bottom: 0.85rem;
}

.tool-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.tool-link-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.28rem;
  padding: 0.22rem 0.6rem;
  font-size: 0.76rem;
  font-weight: 600;
  border-radius: 2rem;
  border: 1.5px solid $primary;
  color: $primary;
  text-decoration: none;
  background: transparent;
  transition: background 0.15s ease, color 0.15s ease;

  &:hover {
    background: $primary;
    color: white;
    text-decoration: none;
  }
}

.tool-link-paper {
  border-color: $secondary;
  color: $secondary;

  &:hover {
    background: $secondary;
    color: white;
  }
}

.tool-devs {
  flex-shrink: 0;
  width: 175px;
  padding: 1.35rem 1.25rem;
  background: #f8fafc;
  border-left: 1px solid #d5e3f0;
  display: flex;
  flex-direction: column;
  gap: 0.28rem;

  @media (max-width: 768px) {
    width: 100%;
    border-left: none;
    border-top: 1px solid #d5e3f0;
    background: #f8fafc;
  }
}

.tool-devs-title {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: #8a9bae;
  margin-bottom: 0.35rem;
}

.dev-link {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.86rem;
  color: $primary;
  text-decoration: none;
  font-weight: 500;
  line-height: 1.5;

  &:hover {
    color: $secondary;
    text-decoration: underline;
  }
}

.dev-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 1.5px solid #d5e3f0;
}

// ── Team grid (single page) ───────────────────────────────────────────────────
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 1.8rem 1.2rem;
  margin: 2rem 0;
}

.team-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.team-photo {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  object-fit: cover;
  object-position: center top;
  border: 3px solid #d5e3f0;
  box-shadow: 0 2px 10px rgba(39,107,166,0.12);
  margin-bottom: 0.6rem;
  display: block;
}

.team-name {
  font-size: 0.88rem;
  font-weight: 700;
  color: $dark;
  margin-bottom: 0.15rem;
  line-height: 1.3;
}

.team-role {
  font-size: 0.75rem;
  color: #6c757d;
  line-height: 1.35;
}

// Hide navbar brand text — logo alone links to home
.navbar-brand-title {
  display: none;
}

// ── Location section ─────────────────────────────────────────────────────
.location-section {
  display: flex;
  gap: 2.5rem;
  align-items: flex-start;
  margin: 2.5rem 0 1.5rem;

  @media (max-width: 768px) {
    flex-direction: column;
  }
}

.location-text {
  flex: 1;

  .location-title {
    font-size: 1.55rem;
    font-weight: 800;
    color: $primary;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: none;
    position: relative;

    &::after {
      content: "";
      position: absolute;
      bottom: 0; left: 0;
      width: 48px;
      height: 3px;
      background: linear-gradient(90deg, $primary, $secondary);
      border-radius: 2px;
    }
  }

  .location-group {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .location-affil {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .location-addr {
    font-size: 0.92rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .location-email {
    font-size: 0.92rem;
  }
}

.location-img {
  flex: 1;

  img {
    width: 100%;
    border-radius: 0.75rem;
    object-fit: cover;
    box-shadow: 0 4px 20px rgba(39,107,166,0.12);
  }
}

.location-map {
  margin: 1.5rem 0 2.5rem;
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(39,107,166,0.1);
  border: 1px solid #d5e3f0;
}

// ── Team section headings ─────────────────────────────────────────────────────
.team-section-title {
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #8a9bae;
  margin: 2.5rem 0 0.75rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid #e0eaf3;
}

